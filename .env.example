# Copy to .env (`make config`). Used by Docker Compose and optional local tooling.
PYTHONUNBUFFERED=1

# deployment profile: development (default), staging, or production|prod
# ENVIRONMENT=development
# staging + production|prod: /health omits dependency error details; Swagger/OpenAPI hidden unless:
# EXPOSE_OPENAPI_DOCS=true

# App / Compose — config directory (Compose overrides to /app/config for the app container)
VERIFIEDSIGNAL_CONFIG_DIR=config

# FastAPI (local): bind port when using docker compose for `app`
API_PORT=8000

# When true, API uses in-memory job queue (no Redis/ARQ). Default false in Compose.
USE_FAKE_QUEUE=false

# When true, SSE fan-out is in-process only (tests). Default false: Redis pub/sub at REDIS_URL (multi-replica API).
USE_FAKE_EVENT_HUB=false
# Redis channel for SSE JSON lines (all API instances must use the same name).
# EVENT_PUBSUB_CHANNEL=verifiedsignal:sse

# When true, API keeps uploaded bytes in memory instead of MinIO/S3 (local quick tests).
USE_FAKE_STORAGE=false

# When true, after the scaffold pipeline the worker enqueues score_document (stub or HTTP scorer).
# ENQUEUE_SCORE_AFTER_PIPELINE=false
#
# Async scorer: stub (default) or http — see docs/scoring-http.md
# SCORE_ASYNC_BACKEND=stub
# SCORE_HTTP_URL=https://your-scorer.example/v1/score
# Local reference scorer: pdm run reference-http-scorer → http://127.0.0.1:9100/score (see docs/scoring-http.md)
# SCORE_HTTP_BEARER_TOKEN=
# SCORE_HTTP_TIMEOUT_S=120
# SCORE_HTTP_MAX_BODY_CHARS=12000
# SCORE_HTTP_SCORER_VERSION=1.0.0
# When true, successful HTTP score becomes canonical (demotes heuristic).
# SCORE_API_PROMOTE_CANONICAL=false

# ARQ queue name (must match worker `WorkerSettings.queue_name`)
VERIFIEDSIGNAL_ARQ_QUEUE=verifiedsignal:jobs

WORKER_LOG_LEVEL=INFO

# --- PostgreSQL (canonical data) ---
POSTGRES_USER=verifiedsignal
POSTGRES_PASSWORD=verifiedsignal
POSTGRES_DB=verifiedsignal
POSTGRES_PORT=5432
# URL used by the app container (service hostname `postgres`)
DATABASE_URL=postgresql://verifiedsignal:verifiedsignal@postgres:5432/verifiedsignal

# --- Redis (pub/sub, cache, worker coordination) ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible local object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# App / boto3-style (MinIO API from inside Compose network)
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=verifiedsignal
# Path-style addressing (typical for MinIO)
S3_USE_PATH_STYLE=true
# Presigned GET TTL for GET /api/v1/documents/{id}/file?redirect=true (60–604800 seconds)
# DOWNLOAD_PRESIGNED_TTL_SECONDS=3600

# Default collection when multipart upload omits collection_id (matches seeded default-inbox in migration 002)
VERIFIEDSIGNAL_DEFAULT_COLLECTION_ID=00000000-0000-4000-8000-000000000002

# Require Bearer JWT for keyword search and SSE (default true). Set false only for local demos.
# VERIFIEDSIGNAL_REQUIRE_AUTH_SEARCH=true
# VERIFIEDSIGNAL_REQUIRE_AUTH_SSE=true

# Identity: on each Bearer request, create Postgres users + personal org + inbox if missing (Supabase sub).
VERIFIEDSIGNAL_AUTO_PROVISION_IDENTITY=true
# Default in code is false (secure). Set true for local dev when using the seeded default inbox.
VERIFIEDSIGNAL_ALLOW_DEFAULT_COLLECTION_FALLBACK=true

# Per-IP rate limits (slowapi; in-memory per API process). Set false for some test stacks.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH_LOGIN=10/minute
# RATE_LIMIT_AUTH_SIGNUP=5/minute
# RATE_LIMIT_AUTH_REFRESH=60/minute
# RATE_LIMIT_AUTH_RESET=3/minute
# RATE_LIMIT_AUTH_SYNC_IDENTITY=30/minute
# RATE_LIMIT_AUTH_LOGOUT=30/minute
# RATE_LIMIT_DOCUMENTS_INTAKE=60/minute

# Max upload size in bytes (default ~50 MiB)
MAX_UPLOAD_BYTES=52428800

# URL-based intake: POST /api/v1/documents/from-url (worker job fetch_url_and_ingest)
URL_INGEST_ENABLED=true
URL_FETCH_MAX_BYTES=52428800
URL_FETCH_TIMEOUT_S=60
URL_FETCH_MAX_REDIRECTS=5
URL_FETCH_FOLLOW_REDIRECTS=true
# Security: with redirects on, only the initial URL is validated for SSRF; each hop is not.
# For strict boundaries use false or trusted URL lists only.
# Set true only in dev if you need http:// URLs
ALLOW_HTTP_URL_INGEST=false
URL_FETCH_BLOCK_PRIVATE_NETWORKS=true

# --- OpenSearch + Dashboards ---
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_URL=http://opensearch:9200
# Index name for document keyword search (worker index + GET /api/v1/search)
OPENSEARCH_INDEX_NAME=verifiedsignal_documents
# When true, index + search use in-memory dict (pytest / no OpenSearch container)
# USE_FAKE_OPENSEARCH=false

# --- Web UI (Vite dev server) + credentialed CORS ---
# Browser origins allowed to call the API with cookies (refresh token on /auth).
# Match the URL you open for the SPA (default Vite: 5173). Add more comma-separated if needed.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Local HTTP: keep false. Use true only behind HTTPS in production.
AUTH_COOKIE_SECURE=false

# --- Dev-only: create a Supabase email/password user on API startup (ENVIRONMENT=development only) ---
# Matches the Vite dev prefill defaults in apps/web (see apps/web/.env.example). Disable for shared projects.
VERIFIEDSIGNAL_DEV_BOOTSTRAP_AUTH_USER=true
# VERIFIEDSIGNAL_DEV_BOOTSTRAP_AUTH_EMAIL=dev@example.com
# VERIFIEDSIGNAL_DEV_BOOTSTRAP_AUTH_PASSWORD=devpassword123

# --- Supabase Auth (required for /auth/login when the SPA uses the real API) ---
# Demo UI mode (no VITE_API_URL) does not need these.
#
# Values: `supabase status --output json` → use API_URL, ANON_KEY, SERVICE_ROLE_KEY, JWT_SECRET
# (the long eyJ… keys — not only the short Publishable/Secret lines from the table view).
#
# SUPABASE_URL must be reachable FROM wherever FastAPI runs (wrong host → login 503 / ConnectError):
#   • API in Docker (`docker compose` app): use host.docker.internal (Compose maps it on Linux too).
#   • API on host (`pdm run api` / `make api-local`): use http://127.0.0.1:54321 — not host.docker.internal
# SUPABASE_URL=http://host.docker.internal:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
# Newer local Supabase may sign access tokens with ES256 (signing keys). Those are verified via
# JWKS at {SUPABASE_URL}/auth/v1/.well-known/jwks.json — no extra env if SUPABASE_URL is correct.
# Hosted asymmetric: set SUPABASE_JWKS_URL explicitly.
# SUPABASE_JWKS_URL=
# JWT_ALGORITHM=HS256
# JWT_AUDIENCE=authenticated
