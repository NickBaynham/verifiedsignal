# Copy to .env (`make config`). Used by Docker Compose and optional local tooling.
PYTHONUNBUFFERED=1

# App / Compose — config directory (Compose overrides to /app/config for the app container)
VERIFIEDSIGNAL_CONFIG_DIR=config

# FastAPI (local): bind port when using docker compose for `app`
API_PORT=8000

# When true, API uses in-memory job queue (no Redis/ARQ). Default false in Compose.
USE_FAKE_QUEUE=false

# When true, API keeps uploaded bytes in memory instead of MinIO/S3 (local quick tests).
USE_FAKE_STORAGE=false

# ARQ queue name (must match worker `WorkerSettings.queue_name`)
VERIFIEDSIGNAL_ARQ_QUEUE=verifiedsignal:jobs

WORKER_LOG_LEVEL=INFO

# --- PostgreSQL (canonical data) ---
POSTGRES_USER=verifiedsignal
POSTGRES_PASSWORD=verifiedsignal
POSTGRES_DB=verifiedsignal
POSTGRES_PORT=5432
# URL used by the app container (service hostname `postgres`)
DATABASE_URL=postgresql://verifiedsignal:verifiedsignal@postgres:5432/verifiedsignal

# --- Redis (pub/sub, cache, worker coordination) ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible local object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# App / boto3-style (MinIO API from inside Compose network)
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=verifiedsignal
# Path-style addressing (typical for MinIO)
S3_USE_PATH_STYLE=true

# Default collection when multipart upload omits collection_id (matches seeded default-inbox in migration 002)
VERIFIEDSIGNAL_DEFAULT_COLLECTION_ID=00000000-0000-4000-8000-000000000002

# Max upload size in bytes (default ~50 MiB)
MAX_UPLOAD_BYTES=52428800

# --- OpenSearch + Dashboards ---
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_URL=http://opensearch:9200

# --- Supabase Auth (optional; leave empty if unused) ---
# Local: values from `supabase start`. Hosted: project dashboard.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
# Local HS256: leave JWKS empty. Hosted: set SUPABASE_JWKS_URL to auth JWKS and use RS256.
# SUPABASE_JWKS_URL=
# JWT_ALGORITHM=HS256
# JWT_AUDIENCE=authenticated
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# AUTH_COOKIE_SECURE=false
