# Copy to .env.local (gitignored): `cp .env.example .env.local` or `make web-config` from repo root.
# Vite exposes only VITE_* vars to the browser.
#
# API mode (real FastAPI): set origin with no trailing slash — host port maps Docker `app` (default 8000).
VITE_API_URL=http://127.0.0.1:8000
#
# Demo mode: comment out or delete VITE_API_URL — mock data + client-only login (no backend).
#
# Session auth is implemented in FastAPI via Supabase; configure SUPABASE_* in the repo root .env
# for Compose / api-local (see .env.example there). The SPA does not need VITE_SUPABASE_* today.
#
# Optional: override the dev login prefill (defaults match root VERIFIEDSIGNAL_DEV_BOOTSTRAP_AUTH_*).
# VITE_DEV_LOGIN_EMAIL=dev@example.com
# VITE_DEV_LOGIN_PASSWORD=devpassword123
